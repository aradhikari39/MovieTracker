// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider               = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum WatchStatus {
  NOT_WATCHED
  WATCHING
  WATCHED
}

model User {
  id            Int               @id @default(autoincrement())
  firebaseUid   String            @unique
  email         String            @unique
  username      String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  watchlists    Watchlist[]
  ratings       Rating[]
  comments      PersonalComment[]
  movieStatuses UserMovieStatus[]

  createdPolls  Poll[]
  pollVotes     PollVote[]
}

model Movie {
  id              Int               @id @default(autoincrement())
  externalMovieId Int               @unique
  title           String
  releaseYear     Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  watchlistMovies WatchlistMovie[]
  ratings         Rating[]
  comments        PersonalComment[]
  userStatuses    UserMovieStatus[]
}

model Watchlist {
  id          Int              @id @default(autoincrement())
  userId      Int
  name        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  movies      WatchlistMovie[]

  @@unique([userId, name])
}

model WatchlistMovie {
  id          Int        @id @default(autoincrement())
  watchlistId Int
  movieId     Int
  addedAt     DateTime   @default(now())

  watchlist   Watchlist  @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  movie       Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, movieId])
}

model Rating {
  id         Int       @id @default(autoincrement())
  userId     Int
  movieId    Int
  score      Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie      Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model PersonalComment {
  id         Int       @id @default(autoincrement())
  userId     Int
  movieId    Int
  content    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie      Movie     @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model UserMovieStatus {
  id         Int         @id @default(autoincrement())
  userId     Int
  movieId    Int
  status     WatchStatus @default(NOT_WATCHED)
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie      Movie       @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model Poll {
  id          Int          @id @default(autoincrement())
  userId      Int
  question    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  options     PollOption[]
  votes       PollVote[]
}

model PollOption {
  id          Int         @id @default(autoincrement())
  pollId      Int
  text        String

  poll        Poll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes       PollVote[]
}

model PollVote {
  id           Int        @id @default(autoincrement())
  userId       Int
  pollId       Int
  pollOptionId Int
  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option       PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)

  @@unique([userId, pollId])
}